---
const heroImage =
  "https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?w=1920&q=85";

const suitableFor = [
  "Warehousing",
  "Logistics Operations",
  "Electronics Manufacturing",
  "Packaging Units",
  "Vendor Storage",
];
---

<section class="relative min-h-screen flex items-center pt-16">
  <div class="absolute inset-0">
    <img
      src={heroImage}
      alt="Industrial highway frontage with trucks and warehouse sheds near Devanahalli"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/90 via-charcoal/75 to-charcoal/50"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-32">
    <div class="max-w-3xl">
      <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">
        Airport Corridor Industrial Park
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-[1.1] tracking-tight">
        Industrial Land &amp; Ready Sheds Near Foxconn
      </h1>
      <p class="mt-6 text-lg lg:text-xl text-gray-300 leading-relaxed max-w-2xl">
        Highway-facing industrial property strategically located on
        Devanahalli–Doddaballapur Main Road.
      </p>

      <div class="mt-8">
        <p class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">
          Suitable for
        </p>
        <ul class="flex flex-wrap gap-x-6 gap-y-2">
          {
            suitableFor.map((item) => (
              <li class="flex items-center gap-2 text-white text-sm lg:text-base">
                <svg class="w-4 h-4 text-accent shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                    clip-rule="evenodd"
                  />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href="#contact"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-accent hover:bg-accent-hover transition-colors rounded-sm"
        >
          Schedule Site Visit
        </a>
        <a
          href="#brochure"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white border border-white/30 hover:bg-white/10 transition-colors rounded-sm"
        >
          Download Brochure
        </a>
      </div>
    </div>
  </div>
</section>
