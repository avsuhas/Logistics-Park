---
import { site } from '../data/site';

const navLinks = [
  { href: '#location', label: 'Location' },
  { href: '#property', label: 'Property' },
  { href: '#calculator', label: 'Space Planner' },
  { href: '#master-plan', label: 'Master Plan' },
  { href: '#contact', label: 'Contact' },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-sand shadow-sm"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="#" class="flex flex-col leading-tight">
        <span class="text-xl lg:text-2xl font-bold tracking-tight text-charcoal"
          >{site.name}</span
        >
        <span
          class="text-xs lg:text-sm font-semibold text-accent tracking-wide"
          >{site.tagline}</span
        >
      </a>

      <nav class="hidden lg:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-base font-semibold text-charcoal/70 hover:text-accent transition-colors"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <a
        href="#contact"
        class="btn-primary inline-flex items-center px-4 py-2 lg:px-5 lg:py-2.5 text-base font-bold text-white rounded-sm"
      >
        Schedule Site Visit
      </a>
    </div>
  </div>
</header>
