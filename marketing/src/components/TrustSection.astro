---
import { trustPoints } from '../data/site';

const trustImage =
  "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1200&q=80";
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="relative aspect-[4/3] rounded-sm overflow-hidden">
        <img
          src={trustImage}
          alt="Professional logistics yard with container handling and industrial operations"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>

      <div>
        <h2 class="text-3xl lg:text-4xl font-bold text-charcoal tracking-tight">
          Why Companies Choose Us
        </h2>
        <p class="mt-4 text-lg text-steel leading-relaxed">
          Industrial tenants need confidence in ownership, access, and
          long-term partnership — not a typical land broker experience.
        </p>

        <ul class="mt-10 space-y-5">
          {
            trustPoints.map((point) => (
              <li class="flex items-center gap-4">
                <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-charcoal text-white rounded-sm">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </div>
                <span class="text-lg font-semibold text-charcoal">{point}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
