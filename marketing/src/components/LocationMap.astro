---
import { landmarks, site } from '../data/site';

const mapsEmbed = import.meta.env.PUBLIC_GOOGLE_MAPS_EMBED || site.mapsEmbed;
---

<section id="location" class="py-20 lg:py-28 bg-charcoal text-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      <div>
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight">
          Strategic Location Map
        </h2>
        <p class="mt-4 text-gray-400 text-lg leading-relaxed">
          Connected to Foxconn's manufacturing corridor, Kempegowda International
          Airport, Aerospace Park, NH44, and the STRR — the infrastructure tenants
          evaluate first.
        </p>

        <div class="mt-10 overflow-hidden rounded-sm border border-gray-700">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-gray-700">
                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-gray-400">
                  Landmark
                </th>
                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-gray-400">
                  Distance
                </th>
                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden sm:table-cell">
                  Drive Time
                </th>
              </tr>
            </thead>
            <tbody>
              {
                landmarks.map((item) => (
                  <tr class="border-b border-gray-700/50 last:border-0">
                    <td class="py-4 px-4 font-medium">{item.name}</td>
                    <td class="py-4 px-4 text-accent font-semibold">{item.distance}</td>
                    <td class="py-4 px-4 text-gray-400 hidden sm:table-cell">{item.time}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          {
            ['Airport', 'Foxconn', 'Aerospace Park', 'STRR', 'NH44'].map((tag) => (
              <span class="px-3 py-1 text-xs font-semibold uppercase tracking-wider bg-charcoal-light border border-gray-600 rounded-sm text-gray-300">
                {tag}
              </span>
            ))
          }
        </div>
      </div>

      <div class="relative aspect-[4/3] lg:aspect-square rounded-sm overflow-hidden border border-gray-700 bg-charcoal-light">
        <iframe
          src={mapsEmbed}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`${site.name}, Bashettihalli`}
          class="absolute inset-0 w-full h-full"
        ></iframe>
        <p class="absolute bottom-3 left-3 right-3 z-10 text-[10px] text-gray-600 bg-white/90 px-2 py-1 rounded-sm pointer-events-none">
          {site.name} · Bashettihalli, Karnataka
        </p>
      </div>
    </div>
  </div>
</section>
