---
import { site } from '../data/site';

const timelines = [
  'Immediate (0–3 months)',
  'Short-term (3–6 months)',
  'Medium-term (6–12 months)',
  'Planning stage (12+ months)',
];

const areaOptions = [
  'Under 10,000 sq ft',
  '10,000 – 25,000 sq ft',
  '25,000 – 50,000 sq ft',
  '50,000 – 1 acre',
  '1 – 2 acres (partial)',
  'Full site (3 acres)',
];
---

<section id="contact" class="py-20 lg:py-28 bg-charcoal text-white">
  <div class="max-w-3xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold tracking-tight">
        Request Site Visit
      </h2>
      <p class="mt-4 text-gray-400 text-lg">
        Schedule a walkthrough of {site.name}. We'll confirm
        within one business day.
      </p>
    </div>

    <div
      id="site-visit-success"
      hidden
      class="bg-green-900/30 border border-green-700 rounded-sm p-8 text-center"
    >
      <div class="w-16 h-16 mx-auto flex items-center justify-center bg-green-800/50 rounded-full mb-4">
        <svg class="w-8 h-8 text-green-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path
            fill-rule="evenodd"
            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
            clip-rule="evenodd"
          />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-green-400">Request Received</h3>
      <p class="mt-3 text-gray-300 leading-relaxed">
        Thank you for your interest in {site.name}. Our leasing team will reach out
        within one business day to confirm your site visit.
      </p>
      <button
        type="button"
        data-reset-form
        class="mt-6 text-sm text-accent hover:underline"
      >
        Submit another request
      </button>
    </div>

    <form
      id="site-visit-form"
      name="site-visit"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="space-y-6 bg-charcoal-light border border-gray-700 rounded-sm p-8"
    >
      <input type="hidden" name="form-name" value="site-visit" />
      <p class="hidden" aria-hidden="true">
        <label>
          Don't fill this out: <input name="bot-field" />
        </label>
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-300 mb-2">
            Name *
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            class="w-full px-4 py-3 bg-charcoal border border-gray-600 rounded-sm text-white placeholder-gray-500 focus:outline-none focus:border-accent"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="company" class="block text-sm font-medium text-gray-300 mb-2">
            Company *
          </label>
          <input
            id="company"
            name="company"
            type="text"
            required
            class="w-full px-4 py-3 bg-charcoal border border-gray-600 rounded-sm text-white placeholder-gray-500 focus:outline-none focus:border-accent"
            placeholder="Company name"
          />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <label for="phone" class="block text-sm font-medium text-gray-300 mb-2">
            Phone *
          </label>
          <input
            id="phone"
            name="phone"
            type="tel"
            required
            class="w-full px-4 py-3 bg-charcoal border border-gray-600 rounded-sm text-white placeholder-gray-500 focus:outline-none focus:border-accent"
            placeholder="+91"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-300 mb-2">
            Email *
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="w-full px-4 py-3 bg-charcoal border border-gray-600 rounded-sm text-white placeholder-gray-500 focus:outline-none focus:border-accent"
            placeholder="you@company.com"
          />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <label for="area" class="block text-sm font-medium text-gray-300 mb-2">
            Required Area *
          </label>
          <select
            id="area"
            name="required_area"
            required
            class="w-full px-4 py-3 bg-charcoal border border-gray-600 rounded-sm text-white focus:outline-none focus:border-accent"
          >
            <option value="" disabled selected>
              Select area requirement
            </option>
            {areaOptions.map((opt) => (
              <option value={opt}>{opt}</option>
            ))}
          </select>
        </div>
        <div>
          <label for="timeline" class="block text-sm font-medium text-gray-300 mb-2">
            Timeline *
          </label>
          <select
            id="timeline"
            name="timeline"
            required
            class="w-full px-4 py-3 bg-charcoal border border-gray-600 rounded-sm text-white focus:outline-none focus:border-accent"
          >
            <option value="" disabled selected>
              Select timeline
            </option>
            {timelines.map((opt) => (
              <option value={opt}>{opt}</option>
            ))}
          </select>
        </div>
      </div>

      <p id="site-visit-error" hidden class="text-red-400 text-sm"></p>

      <button
        type="submit"
        class="w-full px-8 py-4 text-base font-semibold text-white bg-accent hover:bg-accent-hover disabled:opacity-60 transition-colors rounded-sm"
      >
        Submit Request
      </button>
    </form>
  </div>
</section>
