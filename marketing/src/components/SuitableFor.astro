---
import { useCases } from '../data/site';
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl lg:text-4xl font-bold text-charcoal tracking-tight">
        Suitable For
      </h2>
      <p class="mt-4 text-lg text-steel">
        Designed for the operators driving growth in the Foxconn corridor and
        airport logistics belt.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        useCases.map((useCase) => (
          <div class="group relative overflow-hidden rounded-sm border border-gray-200 bg-white aspect-[16/9]">
            <div class="absolute inset-0 overflow-hidden">
              <img
                src={useCase.image}
                alt={useCase.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-charcoal/80 via-charcoal/20 to-transparent" />
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-8">
              <h3 class="text-2xl font-bold text-white">{useCase.title}</h3>
              <ul class="mt-4 space-y-2">
                {useCase.items.map((item) => (
                  <li class="flex items-center gap-2 text-gray-300 text-sm">
                    <svg class="w-4 h-4 text-accent shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
